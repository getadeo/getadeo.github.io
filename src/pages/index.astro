---
import ArchiveSection from '../components/ArchiveSection.astro';
import EntryList from '../components/EntryList.astro';
import Pagination from '../components/Pagination.astro';
import SitePage from '../layouts/SitePage.astro';
import { getAllEntries, nextPageHref, pageOne } from '../utils/allEntries';

const allEntries = await getAllEntries();
const entries = pageOne(allEntries);
---

<SitePage title="Genesis Tadeo" current="all">
	<ArchiveSection>
		<EntryList entries={entries} />
		<Pagination nextHref={nextPageHref(allEntries, '/page/2/')} />
	</ArchiveSection>
</SitePage>
