---
import { render } from 'astro:content';
import SitePage from '../../layouts/SitePage.astro';
import { getPosts } from '../../utils/allEntries';
import { formatDate } from '../../utils/entries';

export async function getStaticPaths() {
	const posts = await getPosts();
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
const words = post.body?.split(/\s+/).length ?? 0;
const readingTime = Math.max(1, Math.ceil(words / 200));
---

<SitePage title={`${post.data.title} — Genesis Tadeo`} description={post.data.description} current="posts">
	<article class="article-shell">
		<header class="mb-8">
			<h1 class="page-title mb-2">{post.data.title}</h1>
			<div class="article-meta">
				<time datetime={post.data.date.toISOString()}>{formatDate(post.data.date)}</time>
				{post.data.tags && <span> · {post.data.tags.join(', ')}</span>}
				<span> · {readingTime} min read</span>
			</div>
		</header>

		<div class="prose">
			<Content />
		</div>
	</article>
</SitePage>
