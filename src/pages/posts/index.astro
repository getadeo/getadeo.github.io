---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('posts')).sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

<Base title="Posts — Genesis Tadeo">
	<nav>
		<a href="/">&larr; Home</a>
	</nav>

	<header style="margin: 2rem 0 2.5rem;">
		<h1>Posts</h1>
		<p style="color: var(--muted); font-size: 0.95rem;">Running, code, and everything under the sun.</p>
	</header>

	<ul style="list-style: none;">
		{posts.map((post) => (
			<li style="margin-bottom: 1.5rem;">
				<a href={`/posts/${post.id}`} style="font-weight: 500;">{post.data.title}</a>
				<div style="font-size: 0.85rem; color: var(--muted); margin-top: 0.15rem;">
					<time>{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
					{post.data.tags && (
						<span> · {post.data.tags.join(', ')}</span>
					)}
				</div>
				{post.data.description && (
					<p style="font-size: 0.9rem; color: var(--muted); margin-top: 0.25rem;">{post.data.description}</p>
				)}
			</li>
		))}
	</ul>
</Base>
