---
import IconLink from './IconLink.astro';
import RssIcon from './icons/RssIcon.astro';

interface Props {
	href?: string;
	label?: string;
	className?: string;
}

const {
	href = '/rss.xml',
	label = 'RSS feed',
	className = 'rss-nav-link',
} = Astro.props;
---

<IconLink className={className} href={href} label={label}>
	<RssIcon />
</IconLink>
